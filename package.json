    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.4"
  },
  "peerDependencies": {
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "jsdom": "^29.1.1",
    "solid-js": "^1.9.3",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
